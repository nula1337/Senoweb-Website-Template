{% extends "layouts/base.njk" %}

{% block body %}
    {% include "sections/landing.njk" %}

    <!-- GDPR -->
    <section class="py-fluid-16-24 px-fluid-4-8 bg-white dark:bg-stone-950">
        <div class="container m-auto flex flex-col items-center gap-fluid-12-16">
            <!-- TOPPER + HEADING -->
            <div class="flex flex-col items-center gap-2">
                <span class="topper text-center">{{ gdpr.topper }}</span>
                <h2 class="max-w-xl text-balance text-center text-fluid-2xl-5xl text-black dark:text-white font-bold leading-[1.2]! uppercase">{{ gdpr.heading }}</h2>
            </div>

            <div class="max-w-[75ch]">
                {% for item in gdpr.items %}
                    <div class="mb-8">
                        {% if item.heading %}
                            <h3 class="text-fluid-lg-2xl text-black dark:text-white font-semibold mb-4">{{ item.heading }}</h3>
                        {% endif -%}

                        {%- if item.text %}
                            <p class="text-fluid-sm-base text-gray-800 dark:text-gray-200 mb-2">{{ item.text }}</p>
                        {% endif -%}

                        {%- if item.subitems %}
                            <ul class="list-disc max-w-2xl space-y-1 ml-8">
                                {% for subitem in item.subitems %}
                                    <li class="text-gray-800 dark:text-gray-200">{{ subitem.text }}</li>
                                {% endfor %}
                            </ul>
                        {% endif %}
                    </div>
                {% endfor %}
            </div>
        </div>
    </section>
{% endblock body %}